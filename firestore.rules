rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection
    match /users/{userId} {
      // Allow reading user documents for:
      // 1. Anyone (for username lookup during login)
      // 2. Authenticated users reading their own data
      // 3. Admins
      allow read: if true;
      
      // Users can create their own document during registration
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Update rules - users can update their own profile (limited fields) OR admins can update any user
      allow update: if request.auth != null && (
        // Users updating their own profile (but not accountStatus or isAdmin)
        // They CAN update idVerificationStatus when submitting ID, and other ID fields
        (request.auth.uid == userId
         && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['accountStatus', 'isAdmin'])
             || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['idVerificationStatus', 'idVerificationUpdatedAt', 'idType', 'submitId', 'idImageUrl', 'phoneNumber', 'address', 'updatedAt'])))
        // OR admin can update any user with any fields
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true
      );
      
      // Admins can delete user documents
      allow delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // Reports collection
    match /reports/{reportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null 
                            && (resource.data.userId == request.auth.uid 
                            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }
    
    // Service requests collection
    match /service_requests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null 
                            && (resource.data.userId == request.auth.uid 
                            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }
    
    // Lost items collection
    match /lost_items/{itemId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null 
                            && (resource.data.userId == request.auth.uid 
                            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }
    
    // Found items collection
    match /found_items/{itemId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null 
                            && (resource.data.userId == request.auth.uid 
                            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }
    
    // Community news collection
    match /community_news/{newsId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null 
                                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // Barangay information collection (public read, admin write)
    match /barangay_info/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null 
                                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // Barangay officials collection (public read, admin write)
    match /barangay_officials/{officialId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null 
                                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // Barangay facilities collection (public read, admin write)
    match /barangay_facilities/{facilityId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null 
                                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // Supplies collection (public read, users can update quantities when borrowing, admin full access)
    match /supplies/{supplyId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null 
                            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
      // Allow users to update availableQuantity when borrowing/returning
      allow update: if request.auth != null && 
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['availableQuantity', 'updatedAt'])
                    || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }
    
    // Borrowed supplies collection (users can create and update their own borrows, admin can manage all)
    match /borrowed_supplies/{borrowId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && 
                    (resource.data.userId == request.auth.uid 
                    || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
      allow delete: if request.auth != null 
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // Announcements collection (public read, admin write)
    match /announcements/{announcementId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null 
                                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // Notifications collection  
    match /notifications/{notificationId} {
      // Allow all authenticated users to read any notification
      // This is safe because the app filters by userId in the query
      allow read, write: if request.auth != null;
    }
  }
}
