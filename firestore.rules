rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection
    match /users/{userId} {
      // Users can read their own document (CRITICAL for real-time updates!)
      allow read: if request.auth != null && request.auth.uid == userId;
      
      // Users can create their own document during registration
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Users can update their own profile (but not accountStatus)
      allow update: if request.auth != null 
                    && request.auth.uid == userId
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['accountStatus', 'isAdmin']);
      
      // Admins can read and write all user documents
      allow read, write: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // Reports collection
    match /reports/{reportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null 
                            && (resource.data.userId == request.auth.uid 
                            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }
    
    // Service requests collection
    match /service_requests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null 
                            && (resource.data.userId == request.auth.uid 
                            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }
    
    // Lost items collection
    match /lost_items/{itemId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null 
                            && (resource.data.userId == request.auth.uid 
                            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }
    
    // Found items collection
    match /found_items/{itemId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null 
                            && (resource.data.userId == request.auth.uid 
                            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }
    
    // Community news collection
    match /community_news/{newsId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null 
                                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // Barangay information collection (public read, admin write)
    match /barangay_info/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null 
                                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // Barangay officials collection (public read, admin write)
    match /barangay_officials/{officialId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null 
                                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // Supplies collection (public read, users can update quantities when borrowing, admin full access)
    match /supplies/{supplyId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth != null 
                            && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
      // Allow users to update availableQuantity when borrowing/returning
      allow update: if request.auth != null && 
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['availableQuantity', 'updatedAt'])
                    || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }
    
    // Borrowed supplies collection (users can create and update their own borrows, admin can manage all)
    match /borrowed_supplies/{borrowId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null && 
                    (resource.data.userId == request.auth.uid 
                    || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
      allow delete: if request.auth != null 
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
  }
}
