rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // ID Verification images - allow authenticated users to upload their IDs
    match /id_verification/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // User ID images - allow authenticated users to upload their own IDs
    match /user_ids/{allPaths=**} {
      // Allow read for authenticated users (so admins can view)
      allow read: if request.auth != null;
      
      // Allow write for authenticated users
      // The filename should start with the user's UID
      allow write: if request.auth != null;
    }
    
    // Report images
    match /reports/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Service request images
    match /service_requests/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Lost and found images
    match /lost_items/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    match /found_items/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Community news/announcements images
    match /community_news/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Barangay officials photos (admin only)
    match /barangay_officials/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
